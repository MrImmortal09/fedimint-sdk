# Both system frameworks must be declared explicitly because the Rust-compiled
# FedimintReactNativeBindingsFramework.xcframework links against them at compile time
# but CocoaPods does not auto-discover transitive system framework dependencies from
# vendored xcframeworks. Without this declaration the Xcode linker fails with
# "framework not found" / undefined symbols errors at app build time.
#
#   SystemConfiguration - required by `netdev` (via fedimint-connectors → iroh → netwatch →
#                         netdev → system-configuration crate) to enumerate/monitor network
#                         interfaces on Apple platforms.
#   Security            - required by `tokio` and `socket2` (a direct dep in Cargo.toml) for
#                         BSD socket operations and TLS on Apple platforms.
--- ReactNativeBindings.podspec
+++ ReactNativeBindings.podspec
@@ -19,6 +19,7 @@ Pod::Spec.new do |s|
   s.source_files = "ios/**/*.{h,m,mm,swift}", "ios/generated/**/*.{h,m,mm}", "cpp/**/*.{hpp,cpp,c,h}", "cpp/generated/**/*.{hpp,cpp,c,h}"
   s.vendored_frameworks = "FedimintReactNativeBindingsFramework.xcframework"
+  s.frameworks = "SystemConfiguration", "Security"
   s.dependency    "uniffi-bindgen-react-native", "0.29.3-1"
