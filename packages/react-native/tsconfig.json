{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./lib/typescript",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}
